[logging]
 default = FILE:/var/log/krb5libs.log

[libdefaults]
 default_realm = ${AD_DOMAIN}
 dns_lookup_realm = false
 dns_lookup_kdc = true
 ticket_lifetime = 24h
 renew_lifetime = 7d
 forwardable = true

[realms]
 ${AD_DOMAIN} = {
  kdc = ${AD_DC_IP}
  admin_server = ${AD_DC_IP}
 }

[domain_realm]
 .${AD_DOMAIN_LOWER} = ${AD_DOMAIN}
 ${AD_DOMAIN_LOWER} = ${AD_DOMAIN}